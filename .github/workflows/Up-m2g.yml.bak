name: Upload from MEGA to GitHub Release

on:
  workflow_dispatch:
    inputs:
      version_tag:
        description: 'Version tag (e.g., 2.0.0)'
        required: true
        default: '1.0.0'

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Install megatools
        run: |
          sudo apt update
          sudo apt install -y megatools

      # 🔍 Check if a release for this tag already exists
      - name: Check if release exists
        id: check_release
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          if gh release view "v${{ github.event.inputs.version_tag }}" &>/dev/null; then
            echo "exists=true" >> $GITHUB_OUTPUT
          else
            echo "exists=false" >> $GITHUB_OUTPUT
          fi

      # 🏷️ Only create and push the tag for a new release
      - name: Create Git Tag
        if: steps.check_release.outputs.exists == 'false'
        run: |
          git config user.name "GitHub Actions"
          git config user.email "actions@github.com"
          git tag "v${{ github.event.inputs.version_tag }}"
          git push origin "v${{ github.event.inputs.version_tag }}"

      # ☁️ Download files from MEGA public link (no login needed)
      - name: Download files from MEGA
        run: |
          # Your public link - megatools dl handles it directly
          megatools dl "https://mega.nz/file/RxgViYzT#d9cPmW7YLDabE8d9eaewN1GOFtlBMthqqQhA-iy8xbE"
          
          # If the link points to a folder, uncomment this line instead:
          # megatools dl --path ./downloads "https://mega.nz/folder/..."

      - name: Show downloaded files
        run: ls -lh

      # 🆕 New release → create with body & all files
      - name: Create new release
        if: steps.check_release.outputs.exists == 'false'
        uses: softprops/action-gh-release@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tag_name: "v${{ github.event.inputs.version_tag }}"
          name: "apps-full"
          body: |
            🧩 **Native Apps for XoDos**

            ### ✅ What's New
            - Added files from MEGA

            ---
            **👥 Credits**  
            python: @xodiosx • Logos: @sabamdarif  
            **💬 Support**  
            Telegram: [t.me/xodemulatorr](https://t.me/xodemulatorr)  
            Discord: [discord.gg/d2ChVhPfnF](https://discord.gg/d2ChVhPfnF)
          files: |
            *

      # ♻️ Existing release → only add files, don’t touch body/assets
      - name: Add files to existing release
        if: steps.check_release.outputs.exists == 'true'
        uses: softprops/action-gh-release@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tag_name: "v${{ github.event.inputs.version_tag }}"
          files: |
            *
          # No body/name → keeps existing release description untouched
