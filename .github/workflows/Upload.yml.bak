name: Upload XoDos Apps

on:
  workflow_dispatch:
    inputs:
      version_tag:
        description: 'Version tag (e.g., 2.0.0)'
        required: true
        default: '1.0.0'

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Install dependencies
        run: |
          sudo apt update
          sudo apt install -y python3-pip wget
          pip install --upgrade google-api-python-client google-auth-httplib2 google-auth-oauthlib

      # 🔑 Save Google Drive JSON key from secret
      - name: Save GDrive JSON Key
        run: |
          printf '${{ secrets.GDRIVE_KEY }}' > gdrive_key.json

      # 🔍 Check if a release for this tag already exists
      - name: Check if release exists
        id: check_release
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          if gh release view "v${{ github.event.inputs.version_tag }}" &>/dev/null; then
            echo "exists=true" >> $GITHUB_OUTPUT
          else
            echo "exists=false" >> $GITHUB_OUTPUT
          fi

      # 🏷️ Only create and push the tag if this is a brand‑new release
      - name: Create Git Tag
        if: steps.check_release.outputs.exists == 'false'
        run: |
          git config user.name "GitHub Actions"
          git config user.email "actions@github.com"
          git tag "v${{ github.event.inputs.version_tag }}"
          git push origin "v${{ github.event.inputs.version_tag }}"

      # 📥 Download main file using service account (JSON key)
      - name: Download Main APK
        run: |
          python3 <<EOF
          import io
          from google.oauth2 import service_account
          from googleapiclient.discovery import build
          from googleapiclient.http import MediaIoBaseDownload

          FILE_ID = "1wNIysi-MZWl4zT2bHd8CgWM68DMTgugS"   # ← replace with your file ID
          OUTPUT_FILE = "xodos-wine-fex-arm64.tar.xz"

          creds = service_account.Credentials.from_service_account_file("gdrive_key.json")
          service = build('drive', 'v3', credentials=creds)

          request = service.files().get_media(fileId=FILE_ID)
          fh = io.FileIO(OUTPUT_FILE, 'wb')
          downloader = MediaIoBaseDownload(fh, request)

          done = False
          while not done:
              status, done = downloader.next_chunk()
              print(f"Download {int(status.progress() * 100)}%")

          print("Download complete!")
          EOF

      # 📥 Download additional files (use same Python snippet for each)
      - name: Download Additional Files
        run: |
          # Example – uncomment and customize:
          # python3 <<EOF
          # FILE_ID = "your_file_id_here"
          # OUTPUT_FILE = "wine-bionic.tar.xz"
          # ... (same as above download logic) ...
          # EOF
          echo "No additional downloads this run."

      # 🧾 Generate MD5 Checksums for all files to upload
      - name: Generate MD5 Checksums
        id: md5
        run: |
          echo "### File Checksums:" > checksums.txt
          for f in xodos-wine-fex-arm64.tar.xz; do
            if [ -f "$f" ]; then
              md5sum "$f" | awk '{print "- **"$2"** → `"$1"`"}' >> checksums.txt
            fi
          done
          echo "md5_list<<EOF" >> $GITHUB_ENV
          cat checksums.txt >> $GITHUB_ENV
          echo "EOF" >> $GITHUB_ENV

      # 🆕 New release → create it with full description and all files
      - name: Create new release (first time)
        if: steps.check_release.outputs.exists == 'false'
        uses: softprops/action-gh-release@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tag_name: "v${{ github.event.inputs.version_tag }}"
          name: "apps-full"
          body: |
            🧩 **Native Apps for XoDos**

            ### ✅ What's New
            - Initial upload
            -

            ### 🧾 Checksums
            ${{ env.md5_list }}

            ---

            **👥 Credits**
            python: @xodiosx🇾🇪 • 
            Logos: @sabamdarif  

            **💬 Support**
            Telegram: [t.me/xodemulatorr](https://t.me/xodemulatorr)  
            Discord: [discord.gg/d2ChVhPfnF](https://discord.gg/d2ChVhPfnF)
          files: |
            xodos-wine-fex-arm64.tar.xz

      # ♻️ Existing release → just upload new files, keep everything else
      - name: Add files to existing release
        if: steps.check_release.outputs.exists == 'true'
        uses: softprops/action-gh-release@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tag_name: "v${{ github.event.inputs.version_tag }}"
          files: |
            xodos-wine-fex-arm64.tar.xz
            # Add any other newly downloaded files here
          # ❗️ No `body`, no `name` – the existing release stays exactly as it was