def get_remote_file_size(url):
    try:
        req = urllib.request.Request(url, method='HEAD')
        with urllib.request.urlopen(req, timeout=10) as resp:
            size = resp.headers.get('Content-Length')
            if size:
                size = int(size)
                if size < 1024 * 1024:
                    return f"{size / 1024:.1f} KB"
                elif size < 1024 * 1024 * 1024:
                    return f"{size / (1024 * 1024):.1f} MB"
                else:
                    return f"{size / (1024 * 1024 * 1024):.1f} GB"
    except Exception:
        pass
    return "Unknown"

# ========== Archive Layout Detection (for .tar.xz) ==========
def detect_archive_layout(archive_path):
    try:
        result = subprocess.run(["tar", "-tf", archive_path], capture_output=True, text=True, check=True)
        lines = result.stdout.splitlines()
        for line in lines:
            if line.startswith("data/data/com.xodos/files/usr/"):
                return "full_prefix"
        for line in lines:
            if line.startswith("usr/") or line.startswith("home/"):
                return "flat"
        return "unknown"
    except subprocess.CalledProcessError as e:
        raise Exception(f"Failed to inspect archive: {e.stderr}")

def check_architecture_compatibility(archive_path):
    target_arch = platform.machine()
    incompatible = []
    if target_arch == "aarch64":
        incompatible = ["x86_64", "amd64", "i386", "i686"]
    elif target_arch == "x86_64":
        incompatible = ["aarch64", "armv7", "armhf"]
    elif "arm" in target_arch:
        incompatible = ["x86_64", "amd64"]
    if not incompatible:
        return True
    try:
        result = subprocess.run(["tar", "-tf", archive_path], capture_output=True, text=True, check=True)
        for line in result.stdout.splitlines():
            for bad in incompatible:
                if f"/{bad}/" in line or line.startswith(f"{bad}/") or f"/{bad}." in line:
                    return False
        return True
    except Exception:
        return True

# ========== .deb Type Detection ==========
def detect_deb_type(deb_path):
    """Return 'native' if package is Bionic/Termux-like, 'proot' if glibc, or None on failure."""
    try:
        ar_out = subprocess.check_output(["ar", "t", deb_path], stderr=subprocess.DEVNULL, text=True)
        data_tar = None
        for line in ar_out.splitlines():
            if line.startswith("data.tar"):
                data_tar = line.strip()
                break
        if not data_tar:
            return None

        if data_tar.endswith('.xz'):
            tar_opt = 'J'
        elif data_tar.endswith('.gz') or data_tar.endswith('.tgz'):
            tar_opt = 'z'
        elif data_tar.endswith('.bz2'):
            tar_opt = 'j'
        else:
            tar_opt = ''

        ar_p = subprocess.Popen(["ar", "p", deb_path, data_tar], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
        tar_cmd = ["tar", f"-t{tar_opt}"] if tar_opt else ["tar", "-t"]
        tar_p = subprocess.Popen(tar_cmd, stdin=ar_p.stdout, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
        ar_p.stdout.close()
        output = tar_p.communicate()[0].decode()

        if "data/data/com.termux" in output:
            return "native"
        else:
            return "proot"
    except Exception:
        return None

def get_deb_package_name(deb_path):
    """Extract the package name from a .deb file using dpkg-deb."""
    try:
        result = subprocess.run(
            ["dpkg-deb", "--show", "--showformat=${Package}", deb_path],
            capture_output=True, text=True, check=True
        )
        return result.stdout.strip()
    except Exception:
        # Fallback: use the filename without extension as a last resort
        return os.path.splitext(os.path.basename(deb_path))[0].split('_')[0]

# ========== Core Functions ==========
def download_file(url, dest, progress_callback):
    def report(block_num, block_size, total_size):
        if total_size > 0:
            percent = min((block_num * block_size) / total_size * 100, 100)
            GLib.idle_add(progress_callback, percent, f"Downloading... {int(percent)}%")
    urllib.request.urlretrieve(url, dest, reporthook=report)

def extract_archive(archive_path, app_name, progress_callback):
    manifest = get_manifest(app_name)
    os.makedirs(PREFIX, exist_ok=True)
    os.makedirs(BASE_DIR, exist_ok=True)

    layout = detect_archive_layout(archive_path)
    print(f"Detected layout: {layout}")

    if not check_architecture_compatibility(archive_path):
        raise Exception("Archive contains binaries for a different CPU architecture!")

    try:
        result = subprocess.run(["tar", "-tf", archive_path], capture_output=True, text=True, check=True)
        members = [m for m in result.stdout.strip().split('\n') if m and not m.endswith('/')]
        total_files = len(members)
    except subprocess.CalledProcessError as e:
        raise Exception(f"Failed to list archive contents: {e.stderr}")

    if os.path.exists(TMP_EXTRACT):
        shutil.rmtree(TMP_EXTRACT)
    os.makedirs(TMP_EXTRACT, exist_ok=True)

    if layout == "full_prefix":
        cmd = ["tar", "-xJf", archive_path, "-C", TMP_EXTRACT, "--strip-components=5"]
    elif layout == "flat":
        cmd = ["tar", "-xJf", archive_path, "-C", TMP_EXTRACT]
    else:
        raise Exception("Unknown archive structure. Refusing to extract.")

    try:
        subprocess.run(cmd, check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as e:
        raise Exception(f"Extraction failed: {e.stderr}")

    src_root = TMP_EXTRACT
    extracted_paths = []
    count = 0
    actual_files = 0
    for root, _, files in os.walk(src_root):
        actual_files += len(files)
    if actual_files == 0:
        actual_files = total_files

    for root, _, files in os.walk(src_root):
        for f in files:
            src = os.path.join(root, f)
            rel = os.path.relpath(src, src_root)
            if layout == "full_prefix":
                dest = os.path.join(PREFIX, rel)
            else:
                dest = os.path.join(BASE_DIR, rel)
            os.makedirs(os.path.dirname(dest), exist_ok=True)
            file_was_new = not os.path.exists(dest)
            os.replace(src, dest)
            if file_was_new:
                extracted_paths.append(dest)
            count += 1
            percent = (count / actual_files) * 100 if actual_files > 0 else 0
            GLib.idle_add(progress_callback, percent, f"Installing... {int(percent)}%")

    shutil.rmtree(TMP_EXTRACT)

    with open(manifest, 'w') as f:
        for path in extracted_paths:
            f.write(path + '\n')
    GLib.idle_add(progress_callback, 100, f"Installed {len(extracted_paths)} new files")

def install_deb_dependency(deb_url, deb_filename, progress_callback):
    deb_path = os.path.join(ARCHIVE_DIR, deb_filename)
    if not os.path.exists(deb_path):
        GLib.idle_add(progress_callback, 0, f"Downloading {deb_filename}...")
        try:
            download_file(deb_url, deb_path, progress_callback)
        except Exception as e:
            raise Exception(f"Failed to download {deb_filename}: {e}")
    GLib.idle_add(progress_callback, 0, f"Installing {deb_filename}...")
    cmd = ['apt', 'install', deb_path]
    try:
        subprocess.run(cmd, check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as e:
        raise Exception(f"Failed to install {deb_filename}: {e.stderr}")
    GLib.idle_add(progress_callback, 100, f"Installed {deb_filename}")
    return True

