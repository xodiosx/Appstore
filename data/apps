def fix_bin_symlinks():
    bin_dir = os.path.join(PREFIX, "bin")
    if not os.path.isdir(bin_dir):
        return
    for root, _, files in os.walk(bin_dir):
        for name in files:
            path = os.path.join(root, name)
            if os.path.islink(path):
                target = os.readlink(path)
                if "com.termux" in target:
                    os.unlink(path)
                    new_target = target.replace("com.termux", "com.xodos")
                    os.symlink(new_target, path)

def is_protected(file_path, app_name):
    for protected in PROTECTED_DIRS:
        if file_path.startswith(protected):
            app_lower = app_name.lower()
            rest = file_path[len(protected):]
            if rest.startswith('/' + app_lower + '/'):
                return False
            return True
    return False

# ========== Main Install (tar.xz / deb) ==========
def install_app(app_name, archive_name, url, progress_callback, done_callback):
    archive_path = os.path.join(ARCHIVE_DIR, archive_name)
    try:
        if not os.path.exists(archive_path):
            download_file(url, archive_path, progress_callback)

        if archive_name.endswith(".deb"):
            deb_type = detect_deb_type(archive_path)
            if deb_type is None:
                raise Exception("Unable to determine .deb package type (native/proot).")

            GLib.idle_add(progress_callback, 0, f"Installing {app_name} ({deb_type})...")

            if deb_type == "native":
                cmd = ["apt", "i", archive_path]
            else:
                cmd = ["xproot", f"sudo apt install {archive_path} -y"]

            result = subprocess.run(cmd, capture_output=True, text=True)
            if result.returncode != 0:
                raise Exception(f"Debian installation failed:\n{result.stderr}")

            # Write manifest with deb info (archive name + type)
            manifest = get_manifest(app_name)
            os.makedirs(os.path.dirname(manifest), exist_ok=True)
            with open(manifest, 'w') as f:
                f.write(f"deb:{archive_name}\n")
                f.write(f"type:{deb_type}\n")

            GLib.idle_add(progress_callback, 100, f"{app_name} Installed ✅")
            GLib.idle_add(done_callback, True, None)
            return

        extract_archive(archive_path, app_name, progress_callback)

        if app_name in DEB_DEPS:
            for deb_url, deb_filename in DEB_DEPS[app_name]:
                install_deb_dependency(deb_url, deb_filename, progress_callback)

        GLib.idle_add(progress_callback, 100, f"{app_name} Installed ✅")
        GLib.idle_add(done_callback, True, None)

    except Exception as e:
        GLib.idle_add(done_callback, False, str(e))

def remove_app(app_name, done_callback):
    manifest = get_manifest(app_name)
    if not os.path.exists(manifest):
        GLib.idle_add(done_callback, False, "Manifest not found")
        return

    try:
        with open(manifest) as f:
            lines = f.readlines()
        line_list = [line.strip() for line in lines]

        # Check if it's a .deb manifest (first line starts with "deb:")
        if line_list and line_list[0].startswith("deb:"):
            archive_name = line_list[0][4:]           # e.g. "waifudownloader_0.2.69_aarch64.deb"
            deb_type = None
            for line in line_list[1:]:
                if line.startswith("type:"):
                    deb_type = line[5:].strip()
                    break

            archive_path = os.path.join(ARCHIVE_DIR, archive_name)

            if deb_type == "native":
                pkg_name = get_deb_package_name(archive_path)
                # apt remove without -y
                subprocess.run(["apt", "remove", pkg_name], check=False)
            elif deb_type == "proot":
                pkg_name = get_deb_package_name(archive_path)
                # wildcard purge via xproot
                subprocess.run(["xproot", f"sudo apt purge {pkg_name}* -y"], check=False)
            else:
                # Fallback – try both
                subprocess.run(["apt", "purge", "-y", archive_path], stderr=subprocess.DEVNULL, check=False)
                subprocess.run(["xproot", f"sudo apt purge -y {archive_path}"], stderr=subprocess.DEVNULL, check=False)

            # Remove manifest only, keep the archive
            os.remove(manifest)
            GLib.idle_add(done_callback, True, f"{app_name} Removed 🧹")
            return
    except Exception as e:
        GLib.idle_add(done_callback, False, str(e))
        return

    # Normal tar.xz removal (unchanged)
    try:
        with open(manifest) as f:
            files = f.read().splitlines()
        for file in files:
            if not file.startswith(BASE_DIR):
                continue
            if is_protected(file, app_name):
                continue
            if os.path.isfile(file) or os.path.islink(file):
                try:
                    os.remove(file)
                except Exception:
                    pass
        os.remove(manifest)
        GLib.idle_add(done_callback, True, f"{app_name} Removed 🧹")
    except Exception as e:
        GLib.idle_add(done_callback, False, str(e))

def post_remove_recovery(app_name, progress_callback, done_callback):
    if app_name in POST_REMOVE_DEBS:
        try:
            for deb_url, deb_filename in POST_REMOVE_DEBS[app_name]:
                install_deb_dependency(deb_url, deb_filename, progress_callback)
            GLib.idle_add(done_callback, True, f"Recovery packages installed for {app_name}")
        except Exception as e:
            GLib.idle_add(done_callback, False, str(e))
    else:
        GLib.idle_add(done_callback, True, None)

# ========== Update Check ==========
def check_for_updates():
    try:
        req = urllib.request.Request(UPDATE_URL, method='GET')
        with urllib.request.urlopen(req, timeout=10) as resp:
            remote_content = resp.read().decode('utf-8')
    except Exception as e:
        print(f"Update check failed: {e}")
        return False, None
    try:
        with open(CURRENT_SCRIPT, 'r', encoding='utf-8') as f:
            current_content = f.read()
    except Exception as e:
        print(f"Could not read current script: {e}")
        return False, None
    if remote_content != current_content:
        return True, remote_content
    return False, None

def apply_update(remote_content, parent_window):
    script_dir = os.path.dirname(CURRENT_SCRIPT)
    temp_path = os.path.join(script_dir, "appstore_update.tmp")
    try:
        with open(temp_path, 'w', encoding='utf-8') as f:
            f.write(remote_content)
        os.replace(temp_path, CURRENT_SCRIPT)
        os.chmod(CURRENT_SCRIPT, 0o755)
    except Exception as e:
        dialog = Gtk.MessageDialog(
            transient_for=parent_window,
            flags=0,
            message_type=Gtk.MessageType.ERROR,
            buttons=Gtk.ButtonsType.OK,
            text=f"Update failed: {e}"
        )
        dialog.run()
        dialog.destroy()
        return False
    return True

