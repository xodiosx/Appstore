# ========== Helper: create a 64x64 image from a file path ==========
def create_logo_image(path):
    """Return a Gtk.Image scaled to exactly 64x64 pixels, or a fallback icon."""
    if os.path.isfile(path):
        try:
            pixbuf = GdkPixbuf.Pixbuf.new_from_file(path)
            scaled = pixbuf.scale_simple(64, 64, GdkPixbuf.InterpType.BILINEAR)
            return Gtk.Image.new_from_pixbuf(scaled)
        except Exception:
            pass
    # Fallback: default.png or missing icon
    default = os.path.join(LOCAL_LOGO_DIR, "default.png")
    if os.path.isfile(default):
        try:
            pixbuf = GdkPixbuf.Pixbuf.new_from_file(default)
            scaled = pixbuf.scale_simple(64, 64, GdkPixbuf.InterpType.BILINEAR)
            return Gtk.Image.new_from_pixbuf(scaled)
        except Exception:
            pass
    return Gtk.Image.new_from_icon_name("image-missing", Gtk.IconSize.DIALOG)

# ========== Logo Download (URL-encoded app names) ==========
def _logo_url(app_name):
    safe_name = urllib.parse.quote(app_name, safe='')
    return f"{LOGO_BASE_URL}/{safe_name}/logo.png"

def get_remote_logo_size(app_name):
    remote_url = _logo_url(app_name)
    try:
        req = urllib.request.Request(remote_url, method='HEAD')
        with urllib.request.urlopen(req, timeout=10) as resp:
            if resp.status == 200:
                length = resp.headers.get('Content-Length')
                return int(length) if length else None
    except Exception:
        pass
    return None

def download_logo(app_name):
    local_path = os.path.join(LOCAL_LOGO_DIR, app_name, "logo.png")
    remote_url = _logo_url(app_name)

    remote_size = get_remote_logo_size(app_name)
    if remote_size is None:
        return os.path.exists(local_path)

    if os.path.exists(local_path):
        if os.path.getsize(local_path) == remote_size:
            return True

    os.makedirs(os.path.dirname(local_path), exist_ok=True)
    try:
        with urllib.request.urlopen(remote_url, timeout=10) as resp:
            data = resp.read()
            with open(local_path, 'wb') as f:
                f.write(data)
        return True
    except Exception:
        return False

