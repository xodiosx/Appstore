        self.add(vbox)

        # ---------- Header with Categories and Clean buttons ----------
        header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)

        clean_btn = Gtk.Button.new_from_icon_name("edit-clear", Gtk.IconSize.BUTTON)
        clean_btn.set_label(" Clean")
        clean_btn.connect("clicked", self.on_clean_clicked)

        # Categories popover
        self.categories_popover = Gtk.Popover()
        cat_vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        for cat_id, cat_label in CATEGORIES:
            cat_btn = Gtk.Button(label=cat_label, relief=Gtk.ReliefStyle.NONE)
            cat_btn.connect("clicked", self.on_category_selected, cat_id)
            cat_vbox.pack_start(cat_btn, False, False, 0)
            cat_vbox.show_all()          
        self.categories_popover.add(cat_vbox)

        categories_btn = Gtk.MenuButton()
        categories_btn.set_label("Categories")
        categories_btn.set_popover(self.categories_popover)

        header_box.pack_end(clean_btn, False, False, 0)
        header_box.pack_end(categories_btn, False, False, 0)
        vbox.pack_start(header_box, False, False, 0)

        # ---------- Scrolled List ----------
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_shadow_type(Gtk.ShadowType.IN)
        vbox.pack_start(scrolled, True, True, 0)

        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.NONE)
        scrolled.add(self.listbox)

        # ---------- Progress and Status ----------
        self.progress = Gtk.ProgressBar()
        vbox.pack_start(self.progress, False, False, 0)

        self.status_label = Gtk.Label(label="Ready")
        self.status_label.set_halign(Gtk.Align.START)
        vbox.pack_start(self.status_label, False, False, 0)

        self.app_widgets = {}
        self.size_labels = {}
        self.logo_images = {}

        self.current_operation = None
        self.current_install_info = None

        # Build UI rows
        for name, archive, url, desc, cat in apps:
            row = Gtk.ListBoxRow()
            vbox_row = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
            vbox_row.set_margin_top(5)
            vbox_row.set_margin_bottom(5)
            vbox_row.set_margin_start(5)
            vbox_row.set_margin_end(5)
            row.add(vbox_row)

            hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            vbox_row.pack_start(hbox, False, False, 0)

            logo_path = os.path.join(LOCAL_LOGO_DIR, name, "logo.png")
            image = create_logo_image(logo_path)
            hbox.pack_start(image, False, False, 0)
            self.logo_images[name] = image

            label = Gtk.Label(label=name, xalign=0)
            label.set_hexpand(True)
            hbox.pack_start(label, True, True, 0)

            size_label = Gtk.Label(label="Fetching...", xalign=0)
            size_label.set_margin_start(10)
            size_label.set_margin_end(10)
            hbox.pack_start(size_label, False, False, 0)
            self.size_labels[name] = size_label

            install_btn = Gtk.Button(label="Install")
            install_btn.connect("clicked", self.on_install_clicked, name, archive, url)
            hbox.pack_start(install_btn, False, False, 0)

            remove_btn = Gtk.Button(label="Remove")
            remove_btn.connect("clicked", self.on_remove_clicked, name)
            hbox.pack_start(remove_btn, False, False, 0)

            self.app_widgets[name] = {
                'install_btn': install_btn,
                'remove_btn': remove_btn,
                'size_label': size_label
            }

            desc_label = Gtk.Label(label=desc, xalign=0)
            desc_label.set_margin_start(42)
            desc_label.set_opacity(0.7)
            vbox_row.pack_start(desc_label, False, False, 0)

            self.row_category[row] = cat
            self.row_name[row] = name
            self.listbox.add(row)

        # Show everything, then apply initial filter (All Apps)
        self.show_all()
        self.apply_filter(0)

        # Kick off background tasks
        threading.Thread(target=self.fetch_all_sizes, daemon=True).start()
        threading.Thread(target=self.sync_logos_and_refresh, daemon=True).start()

    # ---------- Category Filtering ----------
    def on_category_selected(self, button, cat_id):
        self.current_category = cat_id
        self.apply_filter(cat_id)
        self.categories_popover.hide()

    def apply_filter(self, cat_id):
        """Show only rows matching cat_id; 0 means show all."""
        for row in self.listbox.get_children():
            row_cat = self.row_category.get(row, 0)
            row.set_visible(cat_id == 0 or cat_id == row_cat)

        # Refresh button states for now visible rows
        for row in self.listbox.get_children():
            if row.get_visible():
                name = self.row_name.get(row)
                if name:
                    self.refresh_app_state(name)

    # ---------- Logo & Size Handling ----------
    def sync_logos_and_refresh(self):
        sync_all_logos(self._update_progress)
        GLib.idle_add(self.refresh_all_logo_images)

    def refresh_all_logo_images(self):
        for name in self.logo_images:
            logo_path = os.path.join(LOCAL_LOGO_DIR, name, "logo.png")
            new_image = create_logo_image(logo_path)
            old_image = self.logo_images[name]
            parent = old_image.get_parent()
            if parent:
                parent.remove(old_image)
                parent.pack_start(new_image, False, False, 0)
                parent.reorder_child(new_image, 0)
                new_image.show()
            self.logo_images[name] = new_image

    def fetch_all_sizes(self):
        for name, archive, url, _, _ in apps:
            size_str = get_remote_file_size(url)
            GLib.idle_add(self.update_size_label, name, size_str)

    def update_size_label(self, name, size_str):
        label = self.size_labels.get(name)
        if label:
            label.set_text(size_str)

    # ---------- App State & Operation Lock ----------
    def refresh_app_state(self, app_name):
        widgets = self.app_widgets.get(app_name)
        if not widgets:
            return
        # If an operation is in progress, force all buttons insensitive
        if self.operation_locked:
            widgets['install_btn'].set_sensitive(False)
            widgets['remove_btn'].set_sensitive(False)
            return

        installed = is_installed(app_name)
        if installed:
            widgets['install_btn'].set_label("Installed")
            widgets['install_btn'].set_sensitive(False)
            widgets['remove_btn'].set_sensitive(True)
        else:
            widgets['install_btn'].set_label("Install")
            widgets['install_btn'].set_sensitive(True)
            widgets['remove_btn'].set_sensitive(False)

    # ---------- Install / Remove / Clean ----------
    def on_install_clicked(self, button, name, archive, url):
        if name in deps:
            required = deps[name]
            if not is_installed(required):
                dialog = Gtk.MessageDialog(
                    transient_for=self,
                    flags=0,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.OK,
                    text=f"{name} requires {required} to be installed first."
                )
                dialog.run()
                dialog.destroy()
                return

        self.operation_locked = True
        self._set_all_buttons_sensitive(False)
        self.status_label.set_text(f"Installing {name}...")
        self.progress.set_fraction(0.0)

        self.current_operation = 'install'
        self.current_install_info = (name, archive, url)

        thread = threading.Thread(target=install_app, args=(name, archive, url, self._update_progress, self._on_operation_done))
        thread.daemon = True
        thread.start()

    def on_remove_clicked(self, button, name):
        self.operation_locked = True
        self._set_all_buttons_sensitive(False)
        self.status_label.set_text(f"Removing {name}...")
        self.progress.set_fraction(0.0)

        self.current_operation = 'remove'
        self.current_install_info = None

        def remove_and_recover():
            remove_app(name, lambda success, msg: None)
            post_remove_recovery(name, self._update_progress, self._on_operation_done)

        thread = threading.Thread(target=remove_and_recover)
        thread.daemon = True
        thread.start()

    def _update_progress(self, percent, message):
        if percent == 0:
            self.progress.pulse()
        else:
            self.progress.set_fraction(percent / 100.0)
        self.status_label.set_text(message)

    def _on_operation_done(self, success, message):
        self.operation_locked = False
        self._set_all_buttons_sensitive(True)

        if not success:
            if self.current_operation == 'install':
                dialog = Gtk.MessageDialog(
                    transient_for=self,
                    flags=0,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.YES_NO,
                    text=f"{message}\n\nDo you want to redownload the App package again?"
                )
                response = dialog.run()
                dialog.destroy()
                if response == Gtk.ResponseType.YES:
                    name, archive, url = self.current_install_info
                    archive_path = os.path.join(ARCHIVE_DIR, archive)
                    if os.path.exists(archive_path):
                        os.remove(archive_path)
                    self.status_label.set_text("Redownloading...")
                    self.on_install_clicked(None, name, archive, url)
                    return
            else:
                dialog = Gtk.MessageDialog(
                    transient_for=self,
                    flags=0,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.OK,
                    text=message
                )
                dialog.run()
                dialog.destroy()
        else:
            self.status_label.set_text(message)
            if "Installed" in message:
                refresh_xfce()
                fix_bin_symlinks()

        # Refresh all rows (current filter stays active)
        for name in self.app_widgets:
            self.refresh_app_state(name)
        GLib.timeout_add(2000, lambda: self.progress.set_fraction(0.0) or False)

    def on_clean_clicked(self, button):
        dialog = Gtk.MessageDialog(
            transient_for=self,
            flags=0,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.YES_NO,
            text="This will delete all downloaded logos, archives and manifests.\nAre you sure you want to continue?"
        )
        dialog.set_title("Clean App Store")
        response = dialog.run()
        dialog.destroy()
        if response != Gtk.ResponseType.YES:
            return

        self.operation_locked = True
        self._set_all_buttons_sensitive(False)
        self.status_label.set_text("Cleaning...")
        self.progress.pulse()

        for d in [LOCAL_LOGO_DIR, ARCHIVE_DIR, MANIFEST_DIR]:
            if os.path.exists(d):
                shutil.rmtree(d)
            os.makedirs(d, exist_ok=True)

        # Refresh all states (everything now uninstalled)
        for name in self.app_widgets:
            self.refresh_app_state(name)
        self.refresh_all_logo_images()

        self.status_label.set_text("Cleaned. Refreshing logos...")
        threading.Thread(target=self._post_clean_logo_sync, daemon=True).start()

    def _post_clean_logo_sync(self):
        sync_all_logos(self._update_progress)
        GLib.idle_add(self._post_clean_finish)

    def _post_clean_finish(self):
        self.refresh_all_logo_images()
        self.operation_locked = False
        self._set_all_buttons_sensitive(True)
        self.status_label.set_text("Ready")
        self.progress.set_fraction(0.0)

    def _set_all_buttons_sensitive(self, sensitive):
        """Set all Install/Remove buttons to the given sensitive state, overriding locks."""
        for row in self.listbox.get_children():
            for child in row.get_children():
                for sub in child.get_children():
                    if isinstance(sub, Gtk.Box):
                        for btn in sub.get_children():
                            if isinstance(btn, Gtk.Button):
                                btn.set_sensitive(sensitive)

class AppStoreApplication(Gtk.Application):
    def __init__(self):
        Gtk.Application.__init__(self, application_id="com.xodos.appstore", flags=Gio.ApplicationFlags.FLAGS_NONE)

    def do_activate(self):
        win = self.props.active_window
        if not win:
            win = AppStoreWindow(self)
        win.present()
        GLib.idle_add(self._check_update_async, win)

    def _check_update_async(self, parent_window):
        def run_check():
            update_available, remote_content = check_for_updates()
            if update_available:
                GLib.idle_add(self._prompt_update, parent_window, remote_content)
        threading.Thread(target=run_check, daemon=True).start()

    def _prompt_update(self, parent_window, remote_content):
        dialog = Gtk.MessageDialog(
            transient_for=parent_window,
            flags=0,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.YES_NO,
            text="A new version of the app store is available. Update now?"
        )
        response = dialog.run()
        dialog.destroy()
        if response == Gtk.ResponseType.YES:
            success = apply_update(remote_content, parent_window)
            if success:
                restart_dialog = Gtk.MessageDialog(
                    transient_for=parent_window,
                    flags=0,
                    message_type=Gtk.MessageType.INFO,
                    buttons=Gtk.ButtonsType.OK,
                    text="Update installed. The app will now restart."
                )
                restart_dialog.run()
                restart_dialog.destroy()
                os.execv(CURRENT_SCRIPT, sys.argv)
            else:
                error_dialog = Gtk.MessageDialog(
                    transient_for=parent_window,
                    flags=0,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.OK,
                    text="Update failed. See error message above."
                )
                error_dialog.run()
                error_dialog.destroy()

if __name__ == "__main__":
    app = AppStoreApplication()
    exit_status = app.run(None)
    sys.exit(exit_status)