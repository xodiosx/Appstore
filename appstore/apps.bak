#!/data/data/com.xodos/files/usr/bin/python3

import os
import sys
import tarfile
import urllib.request
import urllib.error
import threading
import shutil
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib, Gio

# ========== Configuration ==========
PREFIX = "/data/data/com.xodos/files/usr"
ARCHIVE_DIR = os.path.expanduser("~/appstore/archives")
MANIFEST_DIR = os.path.expanduser("~/appstore/manifests")

os.makedirs(ARCHIVE_DIR, exist_ok=True)
os.makedirs(MANIFEST_DIR, exist_ok=True)

# List of apps: (display name, archive filename, download URL)
apps = [
    ("Blender", "xodos-blender.tar.xz", "https://example.com/blender.tar.xz"),
    ("Blender4", "xodos-blender4.tar.xz", "https://example.com/blender4.tar.xz"),
    ("Blender5", "xodos-blender5.tar.xz", "https://example.com/blender5.tar.xz"),
    ("Gimp3", "gimp3.tar.xz", "https://example.com/gimp3.tar.xz"),
    ("Wine Bionic", "wine-bionic.tar.xz", "https://example.com/wine-bionic.tar.xz"),
    ("Wine Glibc", "wine-glibc.tar.xz", "https://example.com/wine-glibc.tar.xz"),
    ("python3.13", "xodos-python3.13.tar.xz", "https://github.com/xodiosx/Appstore/releases/download/1.0.4/xodos-python3.13.tar.xz"),
]

# Dependencies: app name -> required app name
deps = {
    "Blender4": "Blender",
    "Blender5": "Blender",
}

# ========== Helper Functions ==========
def get_manifest(app_name):
    return os.path.join(MANIFEST_DIR, app_name.lower().replace(" ", "_") + ".txt")

def is_installed(app_name):
    return os.path.exists(get_manifest(app_name))

def get_remote_file_size(url):
    """Return human-readable size (e.g., '12.5 MB') or 'Unknown' if not available."""
    try:
        req = urllib.request.Request(url, method='HEAD')
        with urllib.request.urlopen(req, timeout=10) as resp:
            size = resp.headers.get('Content-Length')
            if size:
                size = int(size)
                # Convert to MB or GB
                if size < 1024 * 1024:
                    return f"{size / 1024:.1f} KB"
                elif size < 1024 * 1024 * 1024:
                    return f"{size / (1024 * 1024):.1f} MB"
                else:
                    return f"{size / (1024 * 1024 * 1024):.1f} GB"
    except Exception:
        pass
    return "Unknown"

# ========== Core Functions ==========
def download_file(url, dest, progress_callback):
    def report(block_num, block_size, total_size):
        if total_size > 0:
            percent = min((block_num * block_size) / total_size * 100, 100)
            GLib.idle_add(progress_callback, percent, f"Downloading... {int(percent)}%")
    urllib.request.urlretrieve(url, dest, reporthook=report)

def extract_archive(archive_path, app_name, progress_callback):
    manifest = get_manifest(app_name)
    os.makedirs(PREFIX, exist_ok=True)

    with tarfile.open(archive_path, "r:xz") as tar:
        members = tar.getmembers()
        total = len(members)
        with open(manifest, "w") as f:
            for i, member in enumerate(members):
                parts = member.name.split('/')
                if len(parts) <= 5:
                    percent = (i / total) * 100
                    GLib.idle_add(progress_callback, percent, f"Extracting... {int(percent)}%")
                    continue
                stripped_path = '/'.join(parts[5:])
                target_path = os.path.join(PREFIX, stripped_path)
                os.makedirs(os.path.dirname(target_path), exist_ok=True)

                if member.isdir():
                    os.makedirs(target_path, exist_ok=True)
                else:
                    with tar.extractfile(member) as src, open(target_path, 'wb') as dst:
                        shutil.copyfileobj(src, dst)
                    os.chmod(target_path, member.mode)

                f.write(target_path + "\n")
                percent = (i / total) * 100
                GLib.idle_add(progress_callback, percent, f"Extracting... {int(percent)}%")

def install_app(app_name, archive_name, url, progress_callback, done_callback):
    archive_path = os.path.join(ARCHIVE_DIR, archive_name)
    try:
        if not os.path.exists(archive_path):
            download_file(url, archive_path, progress_callback)
        extract_archive(archive_path, app_name, progress_callback)
        GLib.idle_add(progress_callback, 100, f"{app_name} Installed ✅")
        GLib.idle_add(done_callback, True, None)
    except Exception as e:
        GLib.idle_add(done_callback, False, str(e))

def remove_app(app_name, done_callback):
    manifest = get_manifest(app_name)
    if not os.path.exists(manifest):
        GLib.idle_add(done_callback, False, "Manifest not found")
        return
    try:
        with open(manifest) as f:
            files = f.read().splitlines()
        for file in reversed(files):
            if file.startswith(PREFIX) and os.path.exists(file):
                if os.path.isdir(file):
                    os.rmdir(file)
                else:
                    os.remove(file)
        os.remove(manifest)
        GLib.idle_add(done_callback, True, f"{app_name} Removed 🧹")
    except Exception as e:
        GLib.idle_add(done_callback, False, str(e))

# ========== GTK UI ==========
class AppStoreWindow(Gtk.ApplicationWindow):
    def __init__(self, app):
        Gtk.ApplicationWindow.__init__(self, application=app, title="XoDos App Store")
        self.set_default_size(600, 400)
        self.set_border_width(10)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.add(vbox)

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_shadow_type(Gtk.ShadowType.IN)
        vbox.pack_start(scrolled, True, True, 0)

        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.NONE)
        scrolled.add(self.listbox)

        self.progress = Gtk.ProgressBar()
        vbox.pack_start(self.progress, False, False, 0)

        self.status_label = Gtk.Label(label="Ready")
        self.status_label.set_halign(Gtk.Align.START)
        vbox.pack_start(self.status_label, False, False, 0)

        # Store size labels to update later
        self.size_labels = {}

        # Populate rows
        for name, archive, url in apps:
            row = Gtk.ListBoxRow()
            hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.add(hbox)

            # Logo
            logo_path = os.path.expanduser(f"~/appstore/logo/{name}/logo.png")
            if os.path.isfile(logo_path):
                image = Gtk.Image.new_from_file(logo_path)
                image.set_pixel_size(32)
                hbox.pack_start(image, False, False, 0)

            # App name label
            label = Gtk.Label(label=name, xalign=0)
            hbox.pack_start(label, True, True, 0)

            # Size label
            size_label = Gtk.Label(label="Fetching...", xalign=0)
            size_label.set_margin_start(10)
            size_label.set_margin_end(10)
            hbox.pack_start(size_label, False, False, 0)
            self.size_labels[name] = size_label

            # Install/Remove buttons
            install_btn = Gtk.Button(label="Install")
            install_btn.connect("clicked", self.on_install_clicked, name, archive, url)
            hbox.pack_start(install_btn, False, False, 0)

            remove_btn = Gtk.Button(label="Remove")
            remove_btn.connect("clicked", self.on_remove_clicked, name)
            hbox.pack_start(remove_btn, False, False, 0)

            self.listbox.add(row)

        self.show_all()

        # Start background thread to fetch sizes
        threading.Thread(target=self.fetch_all_sizes, daemon=True).start()

    def fetch_all_sizes(self):
        """Fetch remote sizes for all apps and update UI."""
        for name, archive, url in apps:
            size_str = get_remote_file_size(url)
            GLib.idle_add(self.update_size_label, name, size_str)

    def update_size_label(self, name, size_str):
        """Update size label for an app."""
        label = self.size_labels.get(name)
        if label:
            label.set_text(size_str)

    def on_install_clicked(self, button, name, archive, url):
        # Check dependencies
        if name in deps:
            required = deps[name]
            if not is_installed(required):
                dialog = Gtk.MessageDialog(
                    transient_for=self,
                    flags=0,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.OK,
                    text=f"{name} requires {required} to be installed first."
                )
                dialog.run()
                dialog.destroy()
                return

        self._set_buttons_sensitive(False)
        self.status_label.set_text(f"Installing {name}...")
        self.progress.set_fraction(0.0)

        thread = threading.Thread(target=install_app, args=(name, archive, url, self._update_progress, self._on_operation_done))
        thread.daemon = True
        thread.start()

    def on_remove_clicked(self, button, name):
        self._set_buttons_sensitive(False)
        self.status_label.set_text(f"Removing {name}...")
        self.progress.set_fraction(0.0)

        thread = threading.Thread(target=remove_app, args=(name, self._on_operation_done))
        thread.daemon = True
        thread.start()

    def _update_progress(self, percent, message):
        self.progress.set_fraction(percent / 100.0)
        self.status_label.set_text(message)

    def _on_operation_done(self, success, message):
        self._set_buttons_sensitive(True)
        if not success:
            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text=message
            )
            dialog.run()
            dialog.destroy()
        else:
            self.status_label.set_text(message)
        GLib.timeout_add(2000, lambda: self.progress.set_fraction(0.0) or False)

    def _set_buttons_sensitive(self, sensitive):
        for row in self.listbox.get_children():
            for child in row.get_children():
                for btn in child.get_children():
                    if isinstance(btn, Gtk.Button):
                        btn.set_sensitive(sensitive)

class AppStoreApplication(Gtk.Application):
    def __init__(self):
        Gtk.Application.__init__(self, application_id="com.xodos.appstore", flags=Gio.ApplicationFlags.FLAGS_NONE)

    def do_activate(self):
        win = self.props.active_window
        if not win:
            win = AppStoreWindow(self)
        win.present()

if __name__ == "__main__":
    app = AppStoreApplication()
    exit_status = app.run(None)
    sys.exit(exit_status)